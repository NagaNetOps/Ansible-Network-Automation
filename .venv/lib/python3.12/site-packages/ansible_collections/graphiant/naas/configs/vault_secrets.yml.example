# Example Vault Secrets File
#
# To use this file (secrets are loaded with include_vars and passed to the module in memory only;
# no plaintext password file—use vault-password-file.sh which echoes ANSIBLE_VAULT_PASSPHRASE):
# 1. Copy this file to vault_secrets.yml
#    cp ansible_collections/graphiant/naas/configs/vault_secrets.yml.example ansible_collections/graphiant/naas/configs/vault_secrets.yml
# 2. Edit vault_secrets.yml and replace placeholder values with your secrets
# 3. chmod +x ansible_collections/graphiant/naas/configs/vault-password-file.sh
# 4. export ANSIBLE_VAULT_PASSPHRASE='your-vault-passphrase'
# 5. ansible-vault encrypt ansible_collections/graphiant/naas/configs/vault_secrets.yml --vault-password-file ansible_collections/graphiant/naas/configs/vault-password-file.sh
# 6. Run the playbook with --vault-password-file or --ask-vault-pass:
#    ansible-playbook ansible_collections/graphiant/naas/playbooks/site_to_site_vpn.yml --tags create --vault-password-file ansible_collections/graphiant/naas/configs/vault-password-file.sh
#    ansible-playbook ansible_collections/graphiant/naas/playbooks/edge_services_management.yml --tags configure --vault-password-file ansible_collections/graphiant/naas/configs/vault-password-file.sh
#    ansible-playbook ansible_collections/graphiant/naas/playbooks/edge_services_management.yml --tags configure_without_vault -e config_file=sample_edge_services.yaml
#    ansible-playbook ansible_collections/graphiant/naas/playbooks/macsec_management.yml --tags configure --vault-password-file ansible_collections/graphiant/naas/configs/vault-password-file.sh
#    ansible-playbook ansible_collections/graphiant/naas/playbooks/de_workflows/07_dataex_accept_invitation.yml --vault-password-file ansible_collections/graphiant/naas/configs/vault-password-file.sh
#
# Do not commit vault_secrets.yml.

# Site-to-Site VPN Preshared Keys (keys match sample_site_to_site_vpn.yaml VPN names)
# Replace placeholder values with your actual secrets before encrypting.
vault_site_to_site_vpn_keys:
  s2s-vpn-1-edge-1-static: "replace-with-your-preshared-key1"
  s2s-vpn-2-edge-1-bgp: "replace-with-your-preshared-key2"
  s2s-vpn-1-edge-2-bgp: "replace-with-your-preshared-key3"
  s2s-vpn-2-edge-2-static: "replace-with-your-preshared-key4"

# BGP MD5 Passwords (only for VPNs that use routing.bgp in sample_site_to_site_vpn.yaml)
vault_bgp_md5_passwords:
  s2s-vpn-2-edge-1-bgp: "replace-with-your-bgp-md5-password1"
  s2s-vpn-1-edge-2-bgp: "replace-with-your-bgp-md5-password2"

# Edge LWS passwords — keys must match portal hostnames in sample_edge_services.yaml.
# Required when YAML sets localWebServerPasswordForce: true without localWebServerPassword.
vault_devices_lws_password:
  edge-3-sdktest: "ReplaceMe1"

# Data Exchange BGP MD5 passwords — key = customerName from sample_data_exchange_acceptance.yaml.
# Set md5Password: null in the acceptance YAML; vault fills it per acceptance.
vault_data_exchange_bgp_md5_passwords:
  FinanceInc: "replace-with-your-bgp-md5-password"

# Data Exchange IPSec PSKs — key = customerName → peer name → tunnel.
# Optional: leave psk: null in YAML to use API auto-fill; set here for custom PSKs.
vault_data_exchange_psk:
  FinanceInc:
    peer-1:
      tunnel1: "replace-with-your-psk1"
      tunnel2: "replace-with-your-psk2"
    peer-2:
      tunnel1: "replace-with-your-psk3"
      tunnel2: "replace-with-your-psk4"

# MACsec CAK secrets — keys match sample_macsec.yaml (device → interface → ckn hex → cak hex).
# CKN is plaintext in YAML; when cak is omitted, the module looks up CAK by ckn here.
vault_devices_macsec_psk:
  edge-1-sdktest:
    LAG1:
      "853c6a4eb4f21c58a5bfeb9600dd26e8e045ded866b02a45f5f52cebadcd5956": "868a0a53ea9b6cd4d516b9c26b587efbc5856326a6996d0655cb1851ee99f4df"
    GigabitEthernet7/0/0:
      "23": "12345123451234512345123451234512"
      "24": "1234512345123451234512345123451312345123451234512345123451234513"
  edge-2-sdktest:
    LAG1:
      "1a2b3c4d5e6f7890abcdef1234567890abcdef1234567890abcdef1234567890": "deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef"
    GigabitEthernet8/0/0:
      "31": "abcdefabcdefabcdefabcdefabcdef12"
      "32": "abcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcdefabcd"
